@inherits LayoutComponentBase
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ITenantProvider TenantProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudImage Src="logo.svg" Alt="FrenchInvoice" Width="36" Height="36" Class="ml-3 mr-2" />
        <MudText Typo="Typo.h5">FrenchInvoice</MudText>
        <MudChip T="string" Size="Size.Small" Color="Color.Success" Class="ml-2">Community</MudChip>
        <MudSpacer />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="ToggleDarkMode" />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;

    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1565C0",
            Secondary = "#00897B",
            AppbarBackground = "#1565C0"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#42A5F5",
            Secondary = "#4DB6AC"
        }
    };

    protected override async Task OnInitializedAsync()
    {
        // Garde globale : rediriger vers /onboarding si l'entité n'est pas configurée
        var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (uri == "onboarding") return;

        await TenantProvider.InitializeAsync();
        using var db = DbFactory.CreateDbContext();
        var entity = await db.Entities.FindAsync(TenantProvider.EntityId);
        if (entity != null && !entity.Configured)
        {
            Navigation.NavigateTo("/onboarding");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "darkMode");
            if (stored == "true")
            {
                _isDarkMode = true;
                StateHasChanged();
            }
        }
    }

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        await JS.InvokeVoidAsync("localStorage.setItem", "darkMode", _isDarkMode ? "true" : "false");
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
